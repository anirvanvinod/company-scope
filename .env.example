# -----------------------------------------------------------------------
# CompanyScope — environment variable reference
# Copy this file to .env and fill in the values.
# .env is git-ignored. Never commit real credentials.
# -----------------------------------------------------------------------

# Application
ENVIRONMENT=development

# -----------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://companyscope:companyscope@localhost:5432/companyscope

# -----------------------------------------------------------------------
# Cache and queue (Redis)
# -----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------
# Object storage (MinIO — S3-compatible)
# -----------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DOCUMENTS=companyscope-documents

# -----------------------------------------------------------------------
# Companies House API
# Register at https://developer.company-information.service.gov.uk/
# Rate limit: 600 requests per 5 minutes per application.
# -----------------------------------------------------------------------
CH_API_KEY=

# -----------------------------------------------------------------------
# Application secrets
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------
SECRET_KEY=change-me-in-production

# -----------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------
# URL the browser uses to reach the CompanyScope API.
# Baked into client-side JavaScript at build time (NEXT_PUBLIC_ prefix).
# Companies House is NEVER called from the browser — only via API/worker.
NEXT_PUBLIC_API_URL=http://localhost:8000

# URL Next.js server-side code (server components, route handlers) uses to
# reach the API. Uses the Docker-internal service name in Docker; use
# localhost for local-without-Docker development.
# Never prefixed with NEXT_PUBLIC_ — not exposed to the browser.
API_INTERNAL_URL=http://localhost:8000
